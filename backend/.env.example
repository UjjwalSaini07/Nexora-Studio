# ── LLM Provider: Groq ───────────────────────────────────────────────────────
# Get a free API key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_FALLBACK_MODEL=llama-3.1-8b-instant
LLM_MAX_TOKENS=600
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=22

# ── Datastores ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=vera_bot
REDIS_URL=redis://localhost:6379

# ── Team / submission metadata ────────────────────────────────────────────────
TEAM_NAME=Your Team Name
TEAM_MEMBERS=Ujjwal Saini
CONTACT_EMAIL=you@example.com
BOT_VERSION=1.0.0
SUBMITTED_AT=2026-06-25T08:00:00Z

# ── Operational limits ────────────────────────────────────────────────────────
TICK_MAX_ACTIONS=20
CONTEXT_PAYLOAD_SIZE_CAP_KB=500
REPLY_TIMEOUT_SECONDS=28
TICK_TIMEOUT_SECONDS=25

# ── Auth (optional shared-secret for inbound judge-harness calls) ───────────
ENABLE_AUTH=false
API_AUTH_TOKEN=

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Judge harness caps itself at 10 req/sec (600/min) per challenge-testing-brief.md §5.
# Default here is set above that with headroom for context-push bursts during warmup.
RATE_LIMIT_PER_MINUTE=1200

# ── CORS (comma-separated origins, or "*" for all — dev default) ────────────
CORS_ALLOW_ORIGINS=*

# ── Logging / environment ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── Dataset loading ────────────────────────────────────────────────────────────
# Optional override; otherwise resolves to ../expanded then ../dataset
EXPANDED_DATASET_DIR=
