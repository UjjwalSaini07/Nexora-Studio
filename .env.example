# ── LLM Provider: Groq ───────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_FALLBACK_MODEL=llama-3.1-8b-instant

# ── Datastores (container-network hostnames — do not change for docker-compose) ─
MONGO_DB=nexorabot

# ── Team / submission metadata ────────────────────────────────────────────────
TEAM_NAME=Nexora Bot
TEAM_MEMBERS=Ujjwal Saini
CONTACT_EMAIL=ujjwalsaini0007@gmail.com
BOT_VERSION=1.0.0
SUBMITTED_AT=2026-06-25T08:00:00Z

# ── Auth / rate limiting / CORS ───────────────────────────────────────────────
ENABLE_AUTH=
API_AUTH_TOKEN=
RATE_LIMIT_PER_MINUTE=1200
CORS_ALLOW_ORIGINS=*

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BOT_URL=http://localhost:8080
